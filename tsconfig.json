{
    "compilerOptions": {
        "target": "es2017",
        "module": "commonjs",
        "resolveJsonModule": true,
        "declaration": true,
        "outDir": "./build",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "rootDir": "src",
        "noEmit": true
    },
    "include": ["src/**/*"]
}
