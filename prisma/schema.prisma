// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  client    Client?

  @@map("users")
}

model Client {
  id                    String                  @id @default(uuid())
  name                  String                  @db.VarChar(255)
  weight                Decimal?                @db.Decimal()
  height                Decimal?                @db.Decimal()
  user_id               String                  @unique
  user                  User                    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  clientHistory         ClientHistory[]
  workout               Workout[]
  clientExerciseHistory ClientExerciseHistory[]

  @@map("client")
}

model ClientHistory {
  id        String   @id @default(uuid())
  weight    Decimal? @db.Decimal()
  height    Decimal? @db.Decimal()
  date      DateTime @default(now())
  client_id String   @unique
  client    Client   @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("client_history")
}

model Workout {
  id              String            @id @default(uuid())
  name            String            @db.VarChar(255)
  client_id       String            @unique
  client          Client            @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  workoutExercise WorkoutExercise[]

  @@map("workout")
}

model Exercise {
  id                    String                  @id @default(uuid())
  name                  String                  @db.VarChar(255)
  bodyPart              BodyPart                @map("body_part")
  workoutExercise       WorkoutExercise[]
  clientExerciseHistory ClientExerciseHistory[]

  @@map("exercise")
}

model WorkoutExercise {
  load        Float
  workout_id  String   @unique
  exercise_id String   @unique
  workout     Workout  @relation(fields: [workout_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  exercise    Exercise @relation(fields: [exercise_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([workout_id, exercise_id])
  @@map("workout_exercise")
}

model ClientExerciseHistory {
  load        Float
  date        DateTime @default(now())
  client_id   String   @unique
  exercise_id String   @unique
  client      Client   @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  exercise    Exercise @relation(fields: [exercise_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([client_id, exercise_id])
  @@map("client_exercise_history")
}

enum BodyPart {
  OMBRO
  PEITO
  BICEPS
  TRICEPS
  ANTEBRACO
  PERNA
  COSTAS
}
